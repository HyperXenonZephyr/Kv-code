{
  "name": "@kv-code/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "KV Code desktop workbench",
  "license": "MIT",
  "type": "module",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "check": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "build": "pnpm check && electron-vite build",
    "package:win": "pnpm build && electron-builder --win portable --x64"
  },
  "dependencies": {
    "@aiden0z/pptx-renderer": "^1.2.4",
    "@xterm/addon-fit": "0.10.0",
    "@xterm/xterm": "5.5.0",
    "docx-preview": "^0.4.0",
    "katex": "^0.17.0",
    "lucide-react": "^0.468.0",
    "node-pty": "1.1.0",
    "preact": "^10.29.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "read-excel-file": "^9.3.1",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sucrase": "^3.35.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "26.0.12",
    "electron-vite": "^3.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "dev.kvcode.desktop",
    "productName": "KV Code",
    "asar": true,
    "asarUnpack": [
      "**/node-pty/**"
    ],
    "npmRebuild": false,
    "compression": "maximum",
    "artifactName": "KV-Code-${version}-win-${arch}-portable.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json",
      "!**/*.map"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources",
        "filter": [
          "desktop-logo.ico",
          "desktop-logo.png"
        ]
      }
    ],
    "win": {
      "icon": "resources/desktop-logo.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "requestExecutionLevel": "user"
    }
  }
}
